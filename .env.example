# ============================================================
# PupPal Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PostHog Analytics
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking
SENTRY_DSN=

# Kimi K2.5 / Moonshot AI (direct client access for development)
# For production, move to Supabase Edge Function secrets instead.
EXPO_PUBLIC_KIMI_API_KEY=your-kimi-api-key
EXPO_PUBLIC_KIMI_BASE_URL=https://api.moonshot.ai/v1
EXPO_PUBLIC_KIMI_MODEL=kimi-k2.5

# ============================================================
# These are used in Edge Functions only (not in the client app)
# Set them in Supabase Dashboard → Edge Functions → Secrets
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=
# KIMI_API_KEY=  (same key, but set as Edge Function secret for production)
# GOOGLE_CLOUD_VISION_KEY=
# REVENUECAT_APPLE_API_KEY=
# REVENUECAT_GOOGLE_API_KEY=
# SUPERWALL_API_KEY=
# ONESIGNAL_APP_ID=
