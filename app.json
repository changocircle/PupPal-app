{
  "expo": {
    "name": "PupPal - AI Puppy Training",
    "slug": "puppal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "puppal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "owner": "changocircle",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.puppal.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "PupPal uses your camera to take photos of your puppy for breed detection and your growth journal.",
        "NSPhotoLibraryUsageDescription": "PupPal needs access to your photos to upload puppy pictures for breed detection and your growth journal."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B5C"
      },
      "package": "com.puppal.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "PupPal needs access to your photos to upload puppy pictures.",
          "cameraPermission": "PupPal uses your camera to take photos of your puppy."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B5C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
